{
  "name": "node-typescript-starter",
  "version": "0.1.0",
  "scripts": {
    "check": "tsc --noEmit",
    "dev": "TZ=UTC nodemon main.js",
    "prepare": "husky",
    "lint": "eslint . --fix",
    "start": "TZ=UTC node main.js",
    "test": "TZ=UTC node --test"
  },
  "author": "A. Hassan (https://hassan.web.id)",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": "prettier --write"
  }
}
